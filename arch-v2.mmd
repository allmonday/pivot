graph TD
    subgraph FE["Frontend (React + Vite)"]
        API["api.ts — HTTP 调用层"]
        App["App.tsx — 根布局与路由"]
        Sidebar["Sidebar — 会话列表"]
        ChatPanel["ChatPanel — 对话面板"]
        MessageBubble["MessageBubble — 消息气泡"]
        Tools["tools/ — 工具调用展示"]
        PlanPanel["PlanPanel — 计划面板"]
        HistoryPanel["HistoryPanel — 历史记录"]
        FileExplorer["FileExplorerPanel — 文件浏览"]
        MarkdownRenderer["MarkdownRenderer — Markdown 渲染"]
        TaskList["TaskList — 任务列表"]
    end

    subgraph BE["Backend (FastAPI) — Control Plane"]
        Main["main.py — 应用入口"]

        subgraph Routers["Routers"]
            R_Chat["chat — 对话"]
            R_Sessions["sessions — 会话管理"]
            R_Tasks["tasks — 任务"]
            R_Messages["messages — 消息查询"]
            R_Folders["folders — 文件夹"]
            R_Files["files — 文件"]
            R_Permissions["permissions — 权限"]
        end

        subgraph Services["Services"]
            ClaudeService["claude_service — Claude SDK 调用"]
            ClientManager["client_manager — 客户端管理"]
            History["history — 历史服务"]
            Plan["plan — 计划管理"]
            Summarizer["summarizer — 摘要生成"]
            MCPTools["mcp_tools — MCP 工具"]
            Permissions["permissions — 权限服务"]
            Serializers["serializers — 序列化"]
            BoxshManager["boxsh_manager — 沙箱生命周期管理"]
        end

        subgraph ToolRouter["自定义工具路由"]
            T_Read["Read → boxsh read"]
            T_Write["Write → boxsh write"]
            T_Edit["Edit → boxsh edit"]
            T_Bash["Bash → boxsh bash"]
        end

        DB[("SQLite — 元数据存储")]
        Models["models — ORM 模型"]
        Schemas["schemas — 请求/响应模型"]
    end

    subgraph Sandbox["执行层 — boxsh 沙箱集群"]
        direction LR
        BoxshA["boxsh 进程 A<br/>folder_id: 1<br/>namespace + seccomp 隔离<br/>/data/folder-1/root"]
        BoxshB["boxsh 进程 B<br/>folder_id: 2<br/>namespace + seccomp 隔离<br/>/data/folder-2/root"]
        BoxshC["boxsh 进程 C<br/>folder_id: 3<br/>namespace + seccomp 隔离<br/>/data/folder-3/root"]
    end

    subgraph Cloud["Anthropic Cloud"]
        ClaudeAPI["Claude API<br/>AI 推理"]
    end

    %% ---- Frontend → Backend ----
    API --> R_Chat
    API --> R_Sessions
    API --> R_Tasks
    API --> R_Messages
    API --> R_Folders
    API --> R_Files

    %% ---- Backend 内部 ----
    Routers --> Services
    Services --> DB
    DB --> Models
    Routers --> Schemas
    ClaudeService --> ToolRouter
    ClaudeService -->|"① 发送请求"| ClaudeAPI
    ClaudeAPI -->|"② 返回工具调用指令"| ClaudeService

    %% ---- 工具路由 → boxsh ----
    ToolRouter -->|"③ JSON-RPC 2.0"| BoxshManager
    BoxshManager -->|"stdin/stdout"| BoxshA
    BoxshManager -->|"stdin/stdout"| BoxshB
    BoxshManager -->|"stdin/stdout"| BoxshC

    %% ---- Folder 生命周期 ----
    R_Folders -->|"创建 folder → 启动 boxsh"| BoxshManager
    R_Folders -->|"删除 folder → 停止 boxsh"| BoxshManager

    %% ---- History 服务内部细节 ----
    subgraph HistoryDetail["history 服务内部"]
        direction TB
        H_GetHistory["get_history<br/>SDK 公开 API 获取简洁历史"]
        H_GetFullHistory["get_full_history<br/>SDK 内部 API 获取完整历史"]
        H_ExtractText["extract_plain_text<br/>提取纯文本"]
        H_Filter["_is_visible_entry<br/>过滤 isMeta / isSidechain"]
        H_Chain["_build_full_chain<br/>沿 parentUuid 回溯构建完整链"]
        H_Serialize["serialize_raw_content<br/>解析 text / tool_use / tool_result"]
        H_Merge["_merge_blocks_to_messages<br/>合并相邻同角色块"]

        H_GetHistory --> H_Serialize
        H_GetFullHistory --> H_Filter --> H_Chain --> H_Serialize
        H_Serialize --> H_Merge
        H_Merge -.-> H_ExtractText
    end

    History -.- HistoryDetail

    %% ---- Permissions 服务内部细节 ----
    subgraph PermissionsDetail["permissions 服务内部"]
        direction TB
        P_MakeCallback["make_can_use_tool<br/>创建权限回调注入 SDK"]
        P_Pending["PendingPermission<br/>阻塞等待用户决策"]
        P_Resolve["resolve_permission<br/>根据决策 allow / deny"]
        P_Timeout["asyncio.wait_for<br/>超时自动 deny"]

        P_MakeCallback -->|"工具触发权限检查"| P_Pending
        P_Pending -->|"等待前端决策"| P_Resolve
        P_Pending -->|"超时"| P_Timeout
    end

    Permissions -.- PermissionsDetail
